<?xml version="1.0" encoding="UTF-8"?>
<!--
  声读 SoundRead — Logback 日志配置
  ═══════════════════════════════════
  • dev  环境：彩色控制台 INFO + 自己业务代码 DEBUG
  • prod 环境：JSON 格式文件，按天滚动，分离 error.log
-->
<configuration scan="true" scanPeriod="30 seconds">

    <!-- ==================== 通用变量 ==================== -->
    <property name="APP_NAME" value="soundread-server"/>
    <property name="LOG_DIR" value="logs"/>
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>
    <property name="COLOR_PATTERN"
              value="%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{24}) - %msg%n"/>

    <!-- ==================== 控制台输出 ==================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${COLOR_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== 全量日志文件 (INFO+) ==================== -->
    <appender name="FILE_ALL" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== 错误日志文件 (WARN+) ==================== -->
    <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}-error.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>60</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== 框架级日志级别 ==================== -->
    <!-- MyBatis / 数据库 -->
    <logger name="org.apache.ibatis" level="WARN"/>
    <logger name="com.baomidou.mybatisplus" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="WARN"/>
    <logger name="org.mybatis.spring" level="WARN"/>

    <!-- Spring 框架 -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.springframework.scheduling" level="WARN"/>
    <logger name="org.springframework.web" level="WARN"/>

    <!-- LangChain4j / AI 框架 -->
    <logger name="dev.langchain4j" level="WARN"/>
    <logger name="dev.ai4j" level="WARN"/>

    <!-- 网络 / IO -->
    <logger name="org.apache.http" level="WARN"/>
    <logger name="okhttp3" level="WARN"/>
    <logger name="io.netty" level="WARN"/>

    <!-- ==================== 开发环境 (dev) ==================== -->
    <springProfile name="dev,default">
        <!-- 业务代码 DEBUG，方便调试 -->
        <logger name="com.soundread" level="DEBUG"/>
        <!-- Mapper SQL 日志：需要时取消注释 -->
        <logger name="com.soundread.mapper" level="WARN"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ==================== 生产环境 (prod) ==================== -->
    <springProfile name="prod">
        <!-- 业务代码只打 INFO -->
        <logger name="com.soundread" level="INFO"/>
        <logger name="com.soundread.mapper" level="OFF"/>

        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE_ALL"/>
            <appender-ref ref="FILE_ERROR"/>
        </root>
    </springProfile>

</configuration>
